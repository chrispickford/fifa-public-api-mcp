# EditorConfig — https://editorconfig.org
# Codifies the repo's existing style: 2-space indent, LF, UTF-8, trimmed lines.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown uses two trailing spaces as a hard line break, so don't strip them.
[*.md]
trim_trailing_whitespace = false
